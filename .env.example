# Copy to .env.local and fill in. All calls are live; keys stay server-side.

# Tako (structured data) — STAGING. Get a staging token at https://developer.staging.tako.com
TAKO_API_KEY=
# Staging base host (public API/SDK base URL). Leave unset to use the staging default.
TAKO_HOST=https://staging.trytako.com

# OpenAI (powers the `gpt` baseline and the `gpt_tako` reasoning)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Anthropic (powers the `claude` baseline and the `claude_tako` reasoning)
ANTHROPIC_API_KEY=
# Set to a current model string, e.g. claude-sonnet-4-5 / claude-opus-4-x
ANTHROPIC_MODEL=claude-sonnet-4-5
